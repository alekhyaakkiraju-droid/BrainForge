default_platform(:ios)

platform :ios do
  desc "Deploy prod IPA to App Store via TestFlight"
  lane :deploy_prod do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Sync code signing certificates via match (reads from private git repo)
    match(
      type: "appstore",
      app_identifier: "com.brainforge.app",
      api_key: api_key,
      readonly: true
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "prod",
      configuration: "Release-prod",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "BrainForge.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/BrainForge.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
